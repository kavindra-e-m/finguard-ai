# FinGuard AI - ML Service Environment Configuration

# Service Configuration
DEBUG=false
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=/app/models
PERSONALITY_MODEL_PATH=/app/models/personality_detector.joblib
STRESS_MODEL_PATH=/app/models/stress_predictor.joblib
ANOMALY_MODEL_PATH=/app/models/anomaly_detector.joblib

# Database Configuration
DATABASE_URL=postgresql://finguard_user:finguard_pass@localhost:5432/finguard_db

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Portfolio Optimization
RISK_FREE_RATE=0.06

# Anomaly Detection
ANOMALY_CONTAMINATION=0.05

# Prediction Settings
EXPENSE_FORECAST_PERIODS=3
